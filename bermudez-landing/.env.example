# ============================================================================
# VARIABLES DE ENTORNO - LANDING PAGE BERMÚDEZ CONSTRUCTORES
# ============================================================================
# Copiar este archivo como .env.local y completar con valores reales

# ----------------------------------------------------------------------------
# reCAPTCHA v3 (Obligatorio para producción)
# ----------------------------------------------------------------------------
# Obtener en: https://www.google.com/recaptcha/admin
# Usar reCAPTCHA v3 (no v2)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_v3_secret_key_here

# ----------------------------------------------------------------------------
# Google Sheets API (Obligatorio para guardar leads)
# ----------------------------------------------------------------------------
# 1. Crear proyecto en Google Cloud Console
# 2. Habilitar Google Sheets API
# 3. Crear Service Account
# 4. Descargar JSON de credenciales
# 5. Compartir el spreadsheet con el email del service account

GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Private_Key_Here\n-----END PRIVATE KEY-----\n"
SPREADSHEET_ID=your_google_spreadsheet_id_here

# ID del spreadsheet (se obtiene de la URL):
# https://docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit

# Estructura de la hoja "Leads" (crear con estos headers):
# Timestamp | Nombre | Email | Teléfono | Situación | Estado

# ----------------------------------------------------------------------------
# WhatsApp Business (Opcional - actualizar en código)
# ----------------------------------------------------------------------------
# Número de WhatsApp en formato internacional sin símbolos
# Ejemplo: +573001234567 (actualizar en components/ui/WhatsAppButton.tsx)
NEXT_PUBLIC_WHATSAPP_NUMBER=+573001234567

# ----------------------------------------------------------------------------
# Notificaciones (Opcional)
# ----------------------------------------------------------------------------
# Slack Webhook URL para notificaciones de nuevos leads
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email para notificaciones (si se implementa)
# NOTIFICATION_EMAIL=comercial@bermudezconstructores.com

# ----------------------------------------------------------------------------
# Analytics (Opcional)
# ----------------------------------------------------------------------------
# Google Analytics 4 Measurement ID
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Tag Manager ID
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Meta Pixel ID (Facebook/Instagram Ads)
# NEXT_PUBLIC_META_PIXEL_ID=123456789012345

# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================
#
# 1. NUNCA commitear .env.local a Git (ya está en .gitignore)
# 2. En Vercel, configurar estas variables en Project Settings > Environment Variables
# 3. El PRIVATE_KEY debe incluir los saltos de línea como \n
# 4. Verificar que el Service Account tenga permisos de Editor en el Spreadsheet
# 5. Para desarrollo local sin Google Sheets, el API route permitirá requests
#    pero mostrará advertencias en consola
#
# ============================================================================
